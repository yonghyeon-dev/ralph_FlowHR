generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum TenantPlan {
  TRIAL
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DISABLED
  PENDING
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  PENDING_RESIGNATION
  RESIGNED
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeChangeType {
  HIRE
  TRANSFER
  PROMOTION
  RESIGNATION
  TERMINATION
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  HALF_DAY
}

enum ShiftType {
  REGULAR
  MORNING
  AFTERNOON
  NIGHT
  FLEXIBLE
}

enum ExceptionType {
  CORRECTION
  OVERTIME
  BUSINESS_TRIP
  REMOTE_WORK
}

enum ExceptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClosingStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

enum LeaveType {
  ANNUAL
  HALF_DAY
  SICK
  FAMILY_EVENT
  COMPENSATORY
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ApprovalRequestStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  ESCALATED
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  EXPIRED
  CANCELLED
}

enum DocumentTemplateCategory {
  CONTRACT
  NOTICE
  NDA
  CERTIFICATE
}

enum RequestPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum PayrollRuleType {
  FIXED
  VARIABLE
  DEDUCTION
}

enum PayrollRunStatus {
  DRAFT
  DATA_COLLECTION
  CHANGE_REVIEW
  CALCULATION
  REVIEW
  CONFIRMED
  CANCELLED
}

enum PayslipStatus {
  DRAFT
  CONFIRMED
  SENT
  REISSUE_REQUESTED
}

// ─── Tenant ───────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  plan      TenantPlan   @default(TRIAL)
  status    TenantStatus @default(ACTIVE)
  settings  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users           User[]
  roles           Role[]
  departments     Department[]
  positions       Position[]
  employees       Employee[]
  employeeChanges EmployeeChange[]
  shifts               Shift[]
  shiftAssignments     ShiftAssignment[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  attendanceClosings   AttendanceClosing[]
  leavePolicies        LeavePolicy[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  workflows            Workflow[]
  approvalRequests     ApprovalRequest[]
  approvalSteps        ApprovalStep[]
  documentTemplates    DocumentTemplate[]
  documents            Document[]
  signatures           Signature[]
  payrollRules         PayrollRule[]
  payrollRuns          PayrollRun[]
  payslips             Payslip[]
}

// ─── Role ─────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  permissions Json    @default("[]")
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
}

// ─── User (NextAuth compatible) ───────────────────────────

model User {
  id            String     @id @default(cuid())
  tenantId      String?
  roleId        String?
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  status        UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role     Role?     @relation(fields: [roleId], references: [id])
  accounts Account[]
  sessions Session[]
  employee Employee?
}

// ─── Account (NextAuth compatible) ────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── Session (NextAuth compatible) ────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── VerificationToken (NextAuth compatible) ──────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Department ─────────────────────────────────────────────

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  description String?
  parentId    String?
  managerId   String?
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Department? @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  manager  Employee?   @relation("DepartmentManager", fields: [managerId], references: [id])

  employees          Employee[]
  changesFrom        EmployeeChange[] @relation("ChangeFromDept")
  changesTo          EmployeeChange[] @relation("ChangeToDept")

  @@unique([tenantId, code])
}

// ─── Position ───────────────────────────────────────────────

model Position {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  level       Int     @default(1)
  description String?
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  changesFrom EmployeeChange[] @relation("ChangeFromPos")
  changesTo   EmployeeChange[] @relation("ChangeToPos")

  @@unique([tenantId, name])
}

// ─── Employee ───────────────────────────────────────────────

model Employee {
  id             String          @id @default(cuid())
  tenantId       String
  userId         String?         @unique
  departmentId   String?
  positionId     String?
  employeeNumber String
  name           String
  email          String
  phone          String?
  hireDate       DateTime
  resignDate     DateTime?
  status         EmployeeStatus  @default(ACTIVE)
  type           EmploymentType  @default(FULL_TIME)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  changes            EmployeeChange[]
  managedDepartments Department[]     @relation("DepartmentManager")
  shiftAssignments     ShiftAssignment[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  approvalRequests       ApprovalRequest[] @relation("ApprovalRequester")
  approvalStepsAssigned  ApprovalStep[]    @relation("ApprovalStepApprover")
  sentDocuments          Document[]        @relation("DocumentSender")
  receivedDocuments      Document[]        @relation("DocumentRecipient")
  signatures             Signature[]
  payslips               Payslip[]

  @@unique([tenantId, employeeNumber])
}

// ─── EmployeeChange ─────────────────────────────────────────

model EmployeeChange {
  id               String             @id @default(cuid())
  tenantId         String
  employeeId       String
  type             EmployeeChangeType
  description      String?
  fromDepartmentId String?
  toDepartmentId   String?
  fromPositionId   String?
  toPositionId     String?
  effectiveDate    DateTime

  createdAt DateTime @default(now())

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDepartment Department? @relation("ChangeFromDept", fields: [fromDepartmentId], references: [id])
  toDepartment   Department? @relation("ChangeToDept", fields: [toDepartmentId], references: [id])
  fromPosition   Position?   @relation("ChangeFromPos", fields: [fromPositionId], references: [id])
  toPosition     Position?   @relation("ChangeToPos", fields: [toPositionId], references: [id])
}

// ─── Shift ─────────────────────────────────────────────────

model Shift {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        ShiftType @default(REGULAR)
  startTime   String    // "HH:mm" format
  endTime     String    // "HH:mm" format
  breakMinutes Int      @default(60)
  color       String    @default("#3B82F6")
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]

  @@unique([tenantId, name])
}

// ─── ShiftAssignment ───────────────────────────────────────

model ShiftAssignment {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  shiftId    String
  startDate  DateTime
  endDate    DateTime?

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

// ─── AttendanceRecord ──────────────────────────────────────

model AttendanceRecord {
  id          String           @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime
  status      AttendanceStatus @default(PRESENT)
  checkIn     DateTime?
  checkOut    DateTime?
  workMinutes Int?
  overtime    Int              @default(0)
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
}

// ─── AttendanceException ───────────────────────────────────

model AttendanceException {
  id          String          @id @default(cuid())
  tenantId    String
  employeeId  String
  type        ExceptionType
  status      ExceptionStatus @default(PENDING)
  date        DateTime
  reason      String
  approvedBy  String?
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── AttendanceClosing ─────────────────────────────────────

model AttendanceClosing {
  id         String        @id @default(cuid())
  tenantId   String
  year       Int
  month      Int
  status     ClosingStatus @default(OPEN)
  closedBy   String?
  closedAt   DateTime?
  totalDays  Int           @default(0)
  totalHours Float         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, month])
}

// ─── LeavePolicy ─────────────────────────────────────────

model LeavePolicy {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  type            LeaveType
  description     String?
  defaultDays     Float
  carryOverLimit  Float     @default(0)
  requiresApproval Boolean  @default(true)
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([tenantId, type])
}

// ─── LeaveBalance ────────────────────────────────────────

model LeaveBalance {
  id           String @id @default(cuid())
  tenantId     String
  employeeId   String
  policyId     String
  year         Int
  totalDays    Float
  usedDays     Float  @default(0)
  pendingDays  Float  @default(0)
  carriedOver  Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, policyId, year])
}

// ─── LeaveRequest ────────────────────────────────────────

model LeaveRequest {
  id          String             @id @default(cuid())
  tenantId    String
  employeeId  String
  policyId    String
  status      LeaveRequestStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String?
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

// ─── Workflow ──────────────────────────────────────────────

model Workflow {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  description String?
  triggerType String
  status      WorkflowStatus @default(ACTIVE)
  steps       Json           @default("[]")
  conditions  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalRequests ApprovalRequest[]

  @@unique([tenantId, name])
}

// ─── ApprovalRequest ──────────────────────────────────────

model ApprovalRequest {
  id          String                @id @default(cuid())
  tenantId    String
  workflowId  String
  requesterId String
  title       String
  description String?
  status      ApprovalRequestStatus @default(PENDING)
  priority    RequestPriority       @default(MEDIUM)
  requestType String
  data        Json?
  escalatedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow  Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requester Employee       @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  steps     ApprovalStep[]
}

// ─── ApprovalStep ─────────────────────────────────────────

model ApprovalStep {
  id        String                @id @default(cuid())
  tenantId  String
  requestId String
  stepOrder Int
  approverId String
  status    ApprovalRequestStatus @default(PENDING)
  comment   String?
  actionAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver Employee        @relation("ApprovalStepApprover", fields: [approverId], references: [id], onDelete: Cascade)
}

// ─── DocumentTemplate ───────────────────────────────────

model DocumentTemplate {
  id          String                   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    DocumentTemplateCategory
  content     Json                     @default("{}")
  version     String                   @default("1.0")
  usageCount  Int                      @default(0)
  isActive    Boolean                  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]

  @@unique([tenantId, name])
}

// ─── Document ───────────────────────────────────────────

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  templateId  String
  senderId    String
  recipientId String
  title       String
  status      DocumentStatus @default(DRAFT)
  deadline    DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  completedAt DateTime?
  memo        String?
  notifyEmail Boolean        @default(true)
  notifyReminder Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template  DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sender    Employee         @relation("DocumentSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient Employee         @relation("DocumentRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  signatures Signature[]
}

// ─── Signature ──────────────────────────────────────────

model Signature {
  id            String  @id @default(cuid())
  tenantId      String
  documentId    String
  signerId      String
  signatureData String  @db.Text
  ipAddress     String?
  signedAt      DateTime @default(now())

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   Employee @relation(fields: [signerId], references: [id], onDelete: Cascade)

  @@unique([documentId, signerId])
}

// ─── PayrollRule ───────────────────────────────────────

model PayrollRule {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  type        PayrollRuleType
  description String?
  formula     String
  rate        Float?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

// ─── PayrollRun ───────────────────────────────────────

model PayrollRun {
  id              String           @id @default(cuid())
  tenantId        String
  year            Int
  month           Int
  status          PayrollRunStatus @default(DRAFT)
  currentStep     Int              @default(1)
  totalEmployees  Int              @default(0)
  totalAmount     Float            @default(0)
  confirmedBy     String?
  confirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@unique([tenantId, year, month])
}

// ─── Payslip ──────────────────────────────────────────

model Payslip {
  id            String        @id @default(cuid())
  tenantId      String
  payrollRunId  String
  employeeId    String
  baseSalary    Float
  allowances    Float         @default(0)
  deductions    Float         @default(0)
  netAmount     Float
  breakdown     Json          @default("{}")
  status        PayslipStatus @default(DRAFT)
  sentAt        DateTime?
  viewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
}
