{
  "extends": ["next/core-web-vitals", "prettier"],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["**/*.d.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/__mocks__/**"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
